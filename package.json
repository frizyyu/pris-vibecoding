{
  "name": "pris",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.js dev",
    "build": "node scripts/run-next.js build",
    "start": "node scripts/run-next.js start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/generate-prisma.js",
    "db:migrate": "node scripts/apply-migrations.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
